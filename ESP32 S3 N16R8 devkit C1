// Сетевой обработчик ручной установки времени (СТРОЖАЙШИЙ ЗАПРЕТ НА ИЗМЕНЕНИЯ)
void handleSetTime() {
  if (!server.hasArg("d") || !server.hasArg("m") || !server.hasArg("y") || !server.hasArg("h") || !server.hasArg("min") || !server.hasArg("s")) {
    server.send(400, "text/plain", "Неполные данные времени");
    return;
  }
  struct tm tm_manual;
  tm_manual.tm_mday = server.arg("d").toInt();
  tm_manual.tm_mon  = server.arg("m").toInt() - 1; 
  tm_manual.tm_year = server.arg("y").toInt() - 1900; 
  tm_manual.tm_hour = server.arg("h").toInt();
  tm_manual.tm_min  = server.arg("min").toInt();
  tm_manual.tm_sec  = server.arg("s").toInt();
  tm_manual.tm_isdst = -1;
  time_t t = mktime(&tm_manual);
  if (t == -1) { server.send(200, "text/plain", "Ошибка формат!"); return; }
  struct timeval tv = { .tv_sec = t, .tv_usec = 0 };
  settimeofday(&tv, NULL); 
  server.send(200, "text/plain", "Время сохранено!");
}

