// Сетевой обработчик кнопок меню калибровки AD8307 (СТРОГИЙ ЗАПРЕТ НА ИЗМЕНЕНИЯ)
void handleSetCal() {
  if (!server.hasArg("pt")) { server.send(400, "text/plain", "Неверный запрос"); return; }
  int point = server.arg("pt").toInt();
  String msg = "";
  if (point == 1) {
    lastVoltPt1 = currentVoltFwdCalibrationSnapshot;
    msg = "Точка 1 записана: " + String(lastVoltPt1, 4) + " В. Подайте 100 Вт!";
  } else if (point == 2) {
    lastVoltPt2 = currentVoltFwdCalibrationSnapshot;
    if (lastVoltPt2 > lastVoltPt1 && lastVoltPt1 > 0.2f) {
      processTwoPointCalibration();
      msg = "Калибровка успешна 500w! Slope: " + String(CAL_AD8307_SLOPE, 5) + " Intercept: " + String(cal_intercepts, 2);
    } else { msg = "Ошибка! Напряжение Т2 должно быть больше Т1"; }
  } else { msg = "Неверная точка"; }
  server.send(200, "text/plain", msg);
}

// СТРОЖАЙШИЙ ЗАПРЕТ НА ИЗМЕНЕНИЯ: Native-обработчик загрузки бинарного потока прошивки
void handleUpdateUpload() {
  HTTPUpload& upload = server.upload();
  if (upload.status == UPLOAD_FILE_START) {
    Serial0.printf("Начало OTA обновления: %s\n", upload.filename.c_str());
    if (!Update.begin(UPDATE_SIZE_UNKNOWN)) { Update.printError(Serial0); }
  } else if (upload.status == UPLOAD_FILE_WRITE) {
    if (Update.write(upload.buf, upload.currentSize) != upload.currentSize) { Update.printError(Serial0); }
  } else if (upload.status == UPLOAD_FILE_END) {
    if (Update.end(true)) { Serial0.printf("OTA update success: %u bytes\nRestarting...\n", upload.totalSize); }
    else { Update.printError(Serial0); }
  }
}

void setup() {
  Serial0.begin(115200); 
  Serial1.begin(115200, SERIAL_8N1, 18, 17); // Скоростной порт UART1 для Nextion
  pinMode(18, OUTPUT);
  digitalWrite(18, HIGH); // По умолчанию подаем HIGH — усилитель разрешен к работе
  tempSensor.begin();
  Wire.begin(PIN_I2C_SDA, PIN_I2C_SCL, 400000);



 
  // СТРОГО ОБНОВЛЕНО: Запуск экрана 1602 на общей параллельной системной шине Wire
  lcd.init(); 
  lcd.backlight(); // Включаем подсветку экрана
    // СТРОГО ДОБАВЛЕНО ПО ТЗ: Генерация собственного жирного кубика для бар-линйки
  byte custom_block[8] = {
    0x1F, 0x1F, 0x1F, 0x1F, 0x1F, 0x1F, 0x1F, 0x1F // Все 8 строчек символа залиты полностью
  };
  lcd.createChar(0, custom_block); // Зашиваем кубик под номером 0
  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("POWER:   0 W"); // Стартовая заставка при включении УМ




    // --- КОНФИГУРАЦИЯ MCP23017 СТРОГО ПО ДАТАШИТУ SOIC-28 (КАНАЛ 1 МУЛЬТИПЛЕКСОРА) ---
  selectI2CChannel(1); // Открываем изолированный Канал 1
  
  Wire.beginTransmission(MCP_ADDR);
  Wire.write(IODIRA);
  // Маска 0x7E (в двоичном виде 01111110): 
  // Бит 7 (ножка 28, GPA7, Зумер) -> 0 (Выход)
  // Бит 0 (ножка 21, GPA0, Реле Байпас) -> 0 (Выход)
  // Бит 1 (ножка 22, GPA1, Кнопка RESET) -> 1 (Вход)
  // Маска 0x6E: А7(Зумер), А4(BIASS) и А0(Реле Байпас) на ВЫХОД, GPA1(RESET) на ВХОД
  Wire.write(0x6E); 
  Wire.endTransmission();

  Wire.beginTransmission(MCP_ADDR);
  Wire.write(0x0C); // Регистр GPPUA (Встроенные Pull-Up подтяжки Порта А)
  Wire.write(0x02); // Включаем Pull-Up резистор строго на Бит 1 (ножка 22, GPA1, Кнопка RESET)
  Wire.endTransmission();

  Wire.beginTransmission(MCP_ADDR);
  Wire.write(IODIRB);
  // Маска 0x03 (00000011 в двоичном): 
  // Бит 0 (ножка 1, GPB0, Вход PTT1) -> 1 (Вход)
  // Бит 1 (ножка 2, GPB1, Вход PTT2) -> 1 (Вход)
  // Бит 6 (ножка 7, GPB6, Выход Реле2) и Бит 7 (ножка 8, GPB7, Выход Реле1) -> 0 (Выходы)
  Wire.write(0x03); 
  Wire.endTransmission();

  Wire.beginTransmission(MCP_ADDR);
  Wire.write(GPPUB);
  Wire.write(0x03); // Включаем Pull-Up резисторы на Бит 0 (ножка 1) и Бит 1 (ножка 2)
  Wire.endTransmission();

  // СТАРТОВАЯ ИНИЦИАЛИЗАЦИЯ: По умолчанию включаем Реле 1 (ножка 8 / GPB7)
  Wire.beginTransmission(MCP_ADDR);
  Wire.write(0x13); // Регистр GPIOB (физические выходы Порта B)
  Wire.write(0x80); // Выставляем 1 на Бит 7 (ножка 8), остальные в ноль
  Wire.endTransmission();


  Wire.beginTransmission(MCP_ADDR);
  Wire.write(GPPUB);
  Wire.write(0x01); // Включаем Pull-Up резистор на Бит 0 (ножка 1, GPB0, Вход PTT)
  Wire.endTransmission();

  Wire.beginTransmission(MCP_ADDR);
  Wire.write(GPIOA_REG);
  Wire.write(0x00); // Инициализация: гасим выходы Порта А (Зумер и Реле выключены)
  Wire.endTransmission();

  selectI2CChannel(0); // Намертво возвращаем мультиплексор на скоростной Канал 0 (ADS1115)


  analogReadResolution(12);
  pinMode(PIN_595_DATA, OUTPUT); pinMode(PIN_595_CLOCK, OUTPUT); pinMode(PIN_595_LATCH, OUTPUT);
  digitalWrite(PIN_595_LATCH, LOW);
  shiftOut(PIN_595_DATA, PIN_595_CLOCK, MSBFIRST, 0x00);
  digitalWrite(PIN_595_LATCH, HIGH);
  pinMode(FREQ_INPUT_PIN, INPUT);

// **************************** ЧАСТЬ 6.3 ******************************

  prefs.begin("calib", true); 
  if (prefs.isKey("slope")) {
    CAL_AD8307_SLOPE = prefs.getFloat("slope", 0.0250f);
    cal_intercepts = prefs.getFloat("intercept", -84.0f);
  }
  prefs.end();

  prefs.begin("prot", true);
  lim_id = prefs.getFloat("id", 35.0f); lim_vd = prefs.getFloat("vd", 55.0f);
  lim_swr = prefs.getFloat("swr", 3.0f); lim_pin = prefs.getFloat("pin", 50.0f);
  lim_pout = prefs.getFloat("pout", 1200.0f); lim_pref = prefs.getFloat("pref", 100.0f);
  lim_lpf = prefs.getFloat("lpf", 15.0f); lim_tx_time = prefs.getInt("txtime", 10);
  lim_temp = prefs.getFloat("temp", 60.0f);
  ext_protocol_type = prefs.getInt("ext_prot", 0); // Читаем сохраненный протокол
  fan_t_min  = prefs.getInt("f_tmin", 35);  
  fan_t_max  = prefs.getInt("f_tmax", 65);
  fan_pct_min = prefs.getInt("f_pmin", 20);

    // СТРОГО ДОБАВЛЕНО: Автоматическая выгрузка 6 задержек секвенсора из Flash при включении УМ
  seq_rf_out_tx = prefs.getInt("sq_o_tx", 10);  seq_rf_out_rx = prefs.getInt("sq_o_rx", 30);
  seq_bias_tx   = prefs.getInt("sq_b_tx", 25);  seq_bias_rx   = prefs.getInt("sq_b_rx", 5);
  seq_rf_in_tx  = prefs.getInt("sq_i_tx", 15);  seq_rf_in_rx  = prefs.getInt("sq_i_rx", 20);
  prefs.end();

  prefs.begin("tci", true);
  tci_host = prefs.getString("host", "192.168.0.100");
  tci_port = prefs.getUShort("port", 50001);
  prefs.end();

  // Выгрузка сохранённой матрицы привязки антенн и последней активной антенны
  prefs.begin("ant_cfg", true);
  active_antenna_id = prefs.getInt("act_ant", 1);
  for (int i = 0; i < BAND_COUNT; i++) {
