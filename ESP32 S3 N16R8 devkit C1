  prefs.end();

   if (!WiFi.config(local_IP, gateway, subnet)) { Serial0.println("Ошибка статического IP"); }

  // Запускаем подключение строго по живым переменным из Flash (таймаут 30 с, без блокировки навсегда)
  WiFi.begin(wifi_ssid_live.c_str(), wifi_pass_live.c_str());
  unsigned long wifiStartMs = millis();
  while (WiFi.status() != WL_CONNECTED && (millis() - wifiStartMs < 30000)) {
    delay(100);
    yield();
  }
  if (WiFi.status() == WL_CONNECTED) {
    Serial0.println("\nWi-Fi подключен успешно!");
  } else {
    Serial0.println("\nWi-Fi: таймаут, продолжаем без сети");
  }

  configTime(gmtOffset_sec, daylightOffset_sec, ntpServer, ntpServer2);

  server.on("/", HTTP_GET, handleRoot); server.on("/data", HTTP_GET, handleData);
  server.on("/set_cal", HTTP_GET, handleSetCal); server.on("/set_time", HTTP_GET, handleSetTime); 
  server.on("/sync_ntp", HTTP_GET, handleSyncNtp); server.on("/save_prot", HTTP_GET, handleSaveProt);  
  server.on("/reset_trip", HTTP_GET, handleResetTrip);
  server.on("/save_ext_proto", HTTP_GET, handleSaveExtProto);
  server.on("/save_tci", HTTP_GET, handleSaveTciSettings);
  server.on("/save_fan", HTTP_GET, handleSaveFanSettings);
  server.on("/save_seq", HTTP_GET, handleSaveSequencerSettings);
  server.on("/set_ant", HTTP_GET, handleSelectAntenna);
  server.on("/get_ant_map", HTTP_GET, handleGetAntMap);
  server.on("/save_ant_map", HTTP_GET, handleSaveAntMap);
  server.on("/save_wifi", HTTP_GET, handleSaveWifiSettings);

  server.on("/toggle_trx", HTTP_GET, []() {
    active_trx_id = (active_trx_id == 1) ? 2 : 1;
    
    // АППАРАТНО ПЕРЕКЛЮЧАЕМ РЕЛЕ КОММУТАЦИИ ВЧ НА ПОРТУ B ПО ДАТАШИТУ
    selectI2CChannel(1);
    Wire.beginTransmission(MCP_ADDR);
    Wire.write(0x13); // Регистр GPIOB (ножки 7 и 8)
    // Маска 0x80 (Бит 7, ножка 8) -> TRX-1, Маска 0x40 (Бит 6, ножка 7) -> TRX-2
    Wire.write(active_trx_id == 2 ? 0x40 : 0x80); 
    Wire.endTransmission();
    selectI2CChannel(0); // НАМЕРТВО ВОЗВРАЩАЕМ МУЛЬТИПЛЕКСОР НА АЦП ДАТЧИКОВ
    
    server.send(200, "text/plain", "OK");
  });

  server.on("/set_bypass", HTTP_GET, []() {
    if (server.hasArg("val")) {
      bypass_state = server.arg("val").toInt();
      
      // АППАРАТНОЕ УПРАВЛЕНИЕ РЕЛЕ НА ПОРТУ А (НОЖКА 21) ПО ДАТАШИТУ
      selectI2CChannel(1);
      Wire.beginTransmission(MCP_ADDR);
      Wire.write(GPIOA_REG);
      
      uint8_t outMask = 0x00;
      if (bypass_state)  outMask |= 0x01; // Бит 0 (ножка 21, GPA0) -> 1 (Включить Реле обхода)
      if (is_tripped)     outMask |= 0x80; // Бит 7 (ножка 28, GPA7) -> 1 (Включить Зумер, если авария)
      
      Wire.write(outMask);
      Wire.endTransmission();
      selectI2CChannel(0); // Возвращаем шину на ADS1115
      
      Serial0.printf("Режим BYPASS изменен: %s\n", bypass_state ? "АКТИВЕН" : "ВЫКЛЮЧЕН");
    }
    server.send(200, "text/plain", "OK");
  });

  server.on("/update", HTTP_POST, []() {
    server.sendHeader("Connection", "close");
    server.send(Update.hasError() ? 500 : 200, "text/plain", Update.hasError() ? "FAIL" : "OK");
    ESP.restart(); 
  }, handleUpdateUpload);
  
  server.on("/fast_data", []() {
      float binaryBuffer[] = { wattsFwd, wattsRef, swr };
      server.sendHeader("Access-Control-Allow-Origin", "*");
      server.send_P(200, "application/octet-stream", (const char*)binaryBuffer, sizeof(binaryBuffer));
  });
  
  server.begin();

  pcnt_unit_config_t unit_config = { .low_limit = -32768, .high_limit = 32767 };
  ESP_ERROR_CHECK(pcnt_new_unit(&unit_config, &pcnt_unit));
  pcnt_chan_config_t chan_config = { .edge_gpio_num = FREQ_INPUT_PIN, .level_gpio_num = -1 };
  ESP_ERROR_CHECK(pcnt_new_channel(pcnt_unit, &chan_config, &pcnt_chan));
  pcnt_event_callbacks_t cbs = { .on_reach = on_pcnt_overflow };
  ESP_ERROR_CHECK(pcnt_unit_register_event_callbacks(pcnt_unit, &cbs, NULL));
  ESP_ERROR_CHECK(pcnt_channel_set_edge_action(pcnt_chan, PCNT_CHANNEL_EDGE_ACTION_INCREASE, PCNT_CHANNEL_EDGE_ACTION_HOLD));
  ESP_ERROR_CHECK(pcnt_unit_add_watch_point(pcnt_unit, 20000));
  ESP_ERROR_CHECK(pcnt_unit_enable(pcnt_unit));
  ESP_ERROR_CHECK(pcnt_unit_clear_count(pcnt_unit));
  ESP_ERROR_CHECK(pcnt_unit_start(pcnt_unit));
}


void loop() {
  server.handleClient();
  tciService();
  
   // --- АППАРАТНЫЙ МОНИТОР АВАРИЙ И ЗУМЕРА НА НОЖКЕ 28 (GPA7) ПО ДАТАШИТУ ---
  checkProtectionTrips();
  static bool lastTripState = false;
  if (is_tripped != lastTripState) {
      lastTripState = is_tripped;
      selectI2CChannel(1);
      Wire.beginTransmission(MCP_ADDR);
      Wire.write(GPIOA_REG);
      
      uint8_t outMask = 0x00;
      if (bypass_state) outMask |= 0x01; // Сохраняем состояние реле обхода на ножке 21
      if (is_tripped)    outMask |= 0x80; // Выставляем плюс строго на ножку 28 (GPA7) при аварии
      
      Wire.write(outMask);
      Wire.endTransmission();
      selectI2CChannel(0);
  }

  // Высокоскоростная накопительная пиковая фильтрация встроенного АЦП (каждые 5 мс)
  static unsigned long lastFastAdcTimer = 0;
  // СТРОГО ИСПРАВЛЕНО: Возвращен точный размер накопительного массива пиков [20]
  static float peakBuffer[20]; 
  static int peakSampleCount = 0;
  static float rawVoltFwdSaved = 0.0f; static float rawVoltRefSaved = 0.0f;

  if (millis() - lastFastAdcTimer >= 5) {
      lastFastAdcTimer = millis();
      int rawFwd = analogRead(PIN_ADC_FWD); int rawRef = analogRead(PIN_ADC_REF);
      float currentSampleFwd = ((float)rawFwd / 4095.0f) * 3.3f; 
      float currentSampleRef = ((float)rawRef / 4095.0f) * 3.3f; 
      currentVoltFwdCalibrationSnapshot = currentSampleFwd;
      peakBuffer[peakSampleCount] = currentSampleFwd; peakSampleCount++;

      if (currentSampleFwd > rawVoltFwdSaved) { rawVoltFwdSaved = currentSampleFwd; rawVoltRefSaved = currentSampleRef; }

      if (peakSampleCount >= 20) {
          peakSampleCount = 0; float maxPeakFwdVolt = 0.0f;
          for (int i = 0; i < 20; i++) { if (peakBuffer[i] > maxPeakFwdVolt) { maxPeakFwdVolt = peakBuffer[i]; } }
          calculateRfParameters(maxPeakFwdVolt, rawVoltRefSaved);
          rawVoltFwdSaved = 0.0f; rawVoltRefSaved = 0.0f;

          int nextionVal = (int)constrain(map((long)wattsFwd, 0, 2000, 0, 100), 0, 100);
          Serial1.print("j0.val="); Serial1.print(nextionVal);
          Serial1.write(0xFF); Serial1.write(0xFF); Serial1.write(0xFF); 
      }

        // --- СКОРОСТНОЙ АВТОМАТ MCP23017: ВЗАИМНАЯ БЛОКИРОВКА DUAL-TRX (НОЖКИ 1, 2, 7, 8 ПОРТА B) ---
      selectI2CChannel(1); // Открываем изолированный Канал 1 мультиплексора
      
      Wire.beginTransmission(MCP_ADDR);
      Wire.write(0x13); // Обращаемся строго к регистру GPIOB (физические пины Порта B)
      Wire.endTransmission(); // Чистый и безопасный Си-код закрытия кадра I2C
      
      Wire.requestFrom(MCP_ADDR, 1);
      if (Wire.available()) {
          uint8_t portBValue = Wire.read();
          
          // По даташиту SOIC-28: логический ноль на входе означает замыкание педали на землю (TX)
          ptt1_active = (portBValue & 0x01) == 0; // Ножка 1 (GPB0) -> Сигнал PTT от TRX-1
          ptt2_active = (portBValue & 0x02) == 0; // Ножка 2 (GPB1) -> Сигнал PTT от TRX-2
          
          int oldTrx = active_trx_id;
          
          // Автоматическая аппаратная коммутация по приоритету первого нажатия (Interlocking)
          if (ptt1_active && active_trx_id != 1) { 
              active_trx_id = 1; 
          } 
          else if (ptt2_active && active_trx_id != 2) { 
              active_trx_id = 2; 
          }
          
          // Если состояние трансиверов изменилось аппаратно от педали — мгновенно переключаем реле Порта B
          if (active_trx_id != oldTrx) {
              Wire.beginTransmission(MCP_ADDR);
              Wire.write(0x13); // Обращаемся к регистру GPIOB
              // Маска 0x80 (10000000) -> Вкл Реле 1 (ножка 8 / GPB7), Маска 0x40 (01000000) -> Вкл Реле 2 (ножка 7 / GPB6)
              Wire.write(active_trx_id == 2 ? 0x40 : 0x80); 
              Wire.endTransmission();
          }

                    // СТРОЖАЙШЕЕ ВЕТО НА БЛОКИРОВКУ ПЕРЕДАЧИ ЛДМОС (BIASS НА НОЖКЕ 25 / GPA4)
          // Перевод в режим TX (подача +3.3V смещения на затворы) разрешен только если УМ не в аварии, 
          // режим BYPASS полностью выключен и нажат PTT именно того аппарата, который сейчас АКТИВЕН!
          bool current_ptt = (active_trx_id == 2) ? ptt2_active : ptt1_active;
          
          if (!is_tripped && bypass_state == 0) {
              int newBiassState = current_ptt ? 1 : 0;
              if (newBiassState != biass_state) {
                  biass_state = newBiassState;
                  
                  Wire.beginTransmission(MCP_ADDR);
                  Wire.write(GPIOA_REG); // СТРОГО ИСПРАВЛЕНО: Возвращен верный системный регистр Порта А
                  
                  uint8_t outMask = 0x00;
                  if (bypass_state) outMask |= 0x01; // Сохраняем Реле Байпас на ножке 21 (GPA0)
                  if (is_tripped)    outMask |= 0x80; // Сохраняем Зумер на ножке 28 (GPA7)
                  if (biass_state)   outMask |= 0x10; // Выставляем +3.3V на выход BIASS (ножка 25 / GPA4) при TX
                  
                  Wire.write(outMask);
                  Wire.endTransmission();
              }
          } else {
              // Если сработала защита или нажат экранный обход — принудительно гасим BIASS на ножке 25 (0V)
              if (biass_state == 1) {
                  biass_state = 0;
                  Wire.beginTransmission(MCP_ADDR);
                  Wire.write(GPIOA_REG); // СТРОГО ИСПРАВЛЕНО: Возвращен верный системный регистр Порта А
                  uint8_t outMask = 0x00;
                  if (bypass_state) outMask |= 0x01;
                  if (is_tripped)    outMask |= 0x80;
                  Wire.write(outMask); // Бит 4 сбрасывается в ноль -> смещение снято
                  Wire.endTransmission();
              }
          }
      }
      
      selectI2CChannel(0); // Мгновенно возвращаем мультиплексор на скоростной Канал 0 (ADS1115 защит)

  }

  static unsigned long lastExtAdcTimer = 0; static uint8_t adcMuxStep = 0; 
  if (millis() - lastExtAdcTimer >= 200) {
      lastExtAdcTimer = millis(); selectI2CChannel(0); 
      if (adcMuxStep == 0) {
          Wire.beginTransmission(0x48); Wire.write(0x00); Wire.endTransmission();
          Wire.requestFrom(0x48, 2);
          if (Wire.available() >= 2) {
              int16_t rawAdcValue = (Wire.read() << 8) | Wire.read();
              float measuredVolts = (float)rawAdcValue * 0.000125f;
              if (measuredVolts < 0.0f) measuredVolts = 0.0f;
              ext_voltage_vd = measuredVolts * 17.12903f; 
          }
          Wire.beginTransmission(0x48); Wire.write(0x01); Wire.write(0xD2); Wire.write(0x83); Wire.endTransmission();
          tempSensor.setWaitForConversion(false); tempSensor.requestTemperatures();
          adcMuxStep = 1;
      } 
      else {
          Wire.beginTransmission(0x48); Wire.write(0x00); Wire.endTransmission();
          Wire.requestFrom(0x48, 2);
          if (Wire.available() >= 2) {
              int16_t rawAdcValue = (Wire.read() << 8) | Wire.read();
              float measuredVolts = (float)rawAdcValue * 0.000125f;
              if (measuredVolts < 0.0f) measuredVolts = 0.0f;
              ext_current_id = measuredVolts * 0.33333f; 
              if (ext_current_id < 0.01f) ext_current_id = 0.00f; 
          }
          float currentTemp = tempSensor.getTempCByIndex(0);
          if (currentTemp > -50.0f && currentTemp < 125.0f) { ext_temperature = currentTemp; }
          Wire.beginTransmission(0x48); Wire.write(0x01); Wire.write(0xC2); Wire.write(0x83); Wire.endTransmission();
          adcMuxStep = 0;
      }
  }

  static unsigned long lastPinReadTimer = 0;
  if (millis() - lastPinReadTimer >= 10) {
      lastPinReadTimer = millis();
      int rawPinAdc = analogRead(PIN_ADC_PIN);
      float voltPinAdc = ((float)rawPinAdc / 4095.0f) * 3.3f;
      wattsPin = (voltPinAdc / 3.3f) * 100.0f;
      if (wattsPin < 0.1f) wattsPin = 0.0f;
      if (wattsPin > 120.0f) wattsPin = 120.0f;
  }

  static unsigned long last_measurement = 0;

  // --- ПРЕЦИЗИОННЫЙ ТРЕХСТУПЕНЧАТЫЙ АВТОМАТ СЕКВЕНСОРА НА MILLIS() (СТРОГО БЕЗ DELAY) ---
  // Берём живое, отлаженное состояние педали current_ptt из вашей второй части кода
  // СТРОГО ИСПРАВЛЕНО: Прямое чтение флага педали активного трансивера вне скобок таймера
  bool sequencer_ptt_input = (active_trx_id == 2) ? ptt2_active : ptt1_active;

  // Аппаратный замок безопасности: если сработала защита или включен BYPASS — мгновенно блокируем передачу
  if (is_tripped || bypass_state == 1) { sequencer_ptt_input = false; }

  if (sequencer_ptt_input) {
      // >>> НАЖАТИЕ ПЕДАЛИ (RX -> TX Переход) <<<
      if (sequencer_state == 0) { 
          sequencer_timer = millis();
          sequencer_state = 1; 
      }
      unsigned long elapsed = millis() - sequencer_timer;

      // СТУПЕНЬ 1: Включение выходного мощного реле RF OUTPUT (4 ножка 1-го чипа 74HC595)
      if (sequencer_state == 1 && elapsed >= (unsigned long)seq_rf_out_tx) {
          current_32bit_lpf_mask |= BIT_RF_OUTPUT_RELAY;
          writeRegister595(current_32bit_lpf_mask);
          sequencer_state = 2;
      }
      // СТУПЕНЬ 2: Включение входного реле раскачки RF INPUT (7 ножка 4-го чипа 74HC595)
      if (sequencer_state == 2 && elapsed >= (unsigned long)seq_rf_in_tx) {
          current_32bit_lpf_mask |= BIT_RF_INPUT_RELAY;
          writeRegister595(current_32bit_lpf_mask);
          sequencer_state = 3;
      }
      // СТУПЕНЬ 3: Плавная синхронизация автомата с вашим включением BIASS в Части 2
      if (sequencer_state == 3 && elapsed >= (unsigned long)seq_bias_tx) {
          sequencer_state = 4; // Матрица TX полностью собрана, УМ в эфире!
      }
  } 
  else {
      // >>> ОТПУСКАНИЕ ПЕДАЛИ (TX -> RX Переход) <<<
      if (sequencer_state == 4 || sequencer_state == 3 || sequencer_state == 2 || sequencer_state == 1) { 
          sequencer_timer = millis();
          sequencer_state = 5; // Переходим на первый шаг безопасного разбора ВЧ-тракта реле
      }
      
      if (sequencer_state >= 5) {
          unsigned long elapsed = millis() - sequencer_timer;

          // СТУПЕНЬ 1: Выдержка времени после мгновенного снятия BIASS в Части 2
          if (sequencer_state == 5 && elapsed >= (unsigned long)seq_bias_rx) {
              sequencer_state = 6;
          }
          // СТУПЕНЬ 2: Выключение входного реле раскачки RF INPUT (Очищаем бит в 4-м чипе 74HC595)
          if (sequencer_state == 6 && elapsed >= (unsigned long)seq_rf_in_rx) {
              current_32bit_lpf_mask &= ~BIT_RF_INPUT_RELAY;
              writeRegister595(current_32bit_lpf_mask);
              sequencer_state = 7;
          }
          // СТУПЕНЬ 3: Выключение выходного мощного реле RF OUTPUT (Очищаем бит в 1-м чипе 74HC595)
          if (sequencer_state == 7 && elapsed >= (unsigned long)seq_rf_out_rx) {
              current_32bit_lpf_mask &= ~BIT_RF_OUTPUT_RELAY;
              writeRegister595(current_32bit_lpf_mask);
              sequencer_state = 0; // Возвращаемся в режим RX чистого сна
          }
      }
  }

  // Передаем признак нажатия PTT в КВ-частотомер (PCNT) — только если активен протокол PCNT
  if (ext_protocol_type == 0) {
    bool is_ptt_pressed = (active_trx_id == 2) ? ptt2_active : ptt1_active;
    if (is_ptt_pressed) {
        if (millis() - last_measurement >= GATE_TIME_MS) {
            int pulse_count = 0; pcnt_unit_get_count(pcnt_unit, &pulse_count);
            int64_t total_pulses = (pcnt_overflow_count * 20000) + pulse_count;
            pcnt_overflow_count = 0; pcnt_unit_clear_count(pcnt_unit);
            unsigned long current_gate = millis() - last_measurement; last_measurement = millis();
            if (total_pulses < 0) total_pulses = 0;

            if (wattsFwd > 0.5f) {
                last_calculated_frequency = ((double)total_pulses * 1000.0 / (double)current_gate) * PRESCALER * calibration_factor;
                final_frequency = (uint32_t)last_calculated_frequency; autoSelectBand(last_calculated_frequency);
            } else { final_frequency = 0; last_calculated_frequency = 0.0; }
            double mhz = (double)final_frequency / 1000000.0;
            Serial0.print("Частота: "); Serial0.print(mhz, 6); Serial0.print(" MHz | Диапазон: "); Serial0.println(current_band_name);
        }
    } else {
        last_measurement = millis(); 
    }
  }

  // --- АВТОМАТИЧЕСКИЙ РАСЧЕТ И УПРАВЛЕНИЕ ШИМ ВЕНТИЛЯТОРА (DEVKIT ПИН 14) ---
  static unsigned long lastFanControlTimer = 0;
  if (millis() - lastFanControlTimer >= 500) { // Корректируем обороты каждые 500 мс, чтобы мотор не дергался
      lastFanControlTimer = millis();
      
      if (ext_temperature < fan_t_min) {
          fan_pwm_percent = 0; // Температура ниже минимума — вентилятор полностью остановлен
      } 
      else if (ext_temperature >= fan_t_max) {
          fan_pwm_percent = 100; // Температура достигла или превысила максимум — вентилятор на 100%
      } 
      else {
          // Линейная интерполяция: плавно рассчитываем обороты между T_MIN и T_MAX
          float scale = (ext_temperature - fan_t_min) / (float)(fan_t_max - fan_t_min);
          fan_pwm_percent = fan_pct_min + (int)(scale * (100 - fan_pct_min));
          fan_pwm_percent = constrain(fan_pwm_percent, fan_pct_min, 100);
      }
      
      // Пересчитываем проценты (0-100%) в аппаратные биты ШИМ таймера LEDC (0-255 бит)
      int pwmDuty = map(fan_pwm_percent, 0, 100, 0, 255);
      ledcWrite(14, pwmDuty); // Физически выдаем ШИМ на вывод 14 платы DevKit
  }

        // СТРОГО ОБНОВЛЕНО: двухстрочный вывод на LCD 1602 — обновление не чаще 100 мс (снижение нагрузки на loop)
    static unsigned long lastLcdUpdate = 0;
    static int lastLcdWatts = -1;
    int curWatts = (int)wattsFwd;
    if (millis() - lastLcdUpdate >= 100 || abs(curWatts - lastLcdWatts) >= 3) {
      lastLcdUpdate = millis();
      lastLcdWatts = curWatts;

      char lcdBuf[20];
      lcd.setCursor(0, 0);
      lcd.print("POWER: ");
      snprintf(lcdBuf, sizeof(lcdBuf), "%4d W", curWatts);
      lcd.print(lcdBuf);

      lcd.setCursor(0, 1);
      float max_scale_power = lim_pout;
      if (max_scale_power <= 0.0f) max_scale_power = 1500.0f;
      int total_segments = 0;
      if (wattsFwd > 1.0f) {
          total_segments = (int)((wattsFwd / max_scale_power) * 16.0f);
          if (total_segments > 16) total_segments = 16;
      }
      for (int i = 0; i < 16; i++) {
          if (i < total_segments) lcd.write(0);
          else lcd.print(' ');
      }
    }
}
