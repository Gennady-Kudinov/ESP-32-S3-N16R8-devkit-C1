/**
 * Функция принудительного выбора активного I2C-канала на мультиплексоре PCA9548A
 */
void selectI2CChannel(uint8_t channel) {
    if (channel > 7) return;
    Wire.beginTransmission(0x70); // Базовый I2C адрес PCA9548A
    Wire.write(1 << channel);     // Посылаем битовую маску для открытия канала
    Wire.endTransmission();
}

// Прецизионная функция последовательной отправки 32 бит во все 4 корпуса 74HC595
void writeRegister595(uint32_t mask) {
    digitalWrite(PIN_595_LATCH, LOW);
    
    // Проталкиваем 4 байта последовательно (от старшего 4-го чипа к младшему 1-му)
    shiftOut(PIN_595_DATA, PIN_595_CLOCK, MSBFIRST, (mask >> 24) & 0xFF); // Четвертый чип (Входное реле)
    shiftOut(PIN_595_DATA, PIN_595_CLOCK, MSBFIRST, (mask >> 16) & 0xFF); // Третий чип
    shiftOut(PIN_595_DATA, PIN_595_CLOCK, MSBFIRST, (mask >> 8) & 0xFF);  // Второй чип
    shiftOut(PIN_595_DATA, PIN_595_CLOCK, MSBFIRST, mask & 0xFF);         // Первый чип (ФНЧ и Выходное реле)
    
    digitalWrite(PIN_595_LATCH, HIGH);
}

/**
 * Интеллектуальное ядро защиты (Protection Monitor). Проверяет 9 триггеров по ТЗ.
 */
void checkProtectionTrips() {
    if (is_tripped) return; 
    String reason = "";
    
    if (ext_current_id > lim_id) {
        reason = "OVERCURRENT Id: " + String(ext_current_id, 2) + "A / Порог: " + String(lim_id, 0) + "A";
    }
    else if (ext_voltage_vd > lim_vd) {
        reason = "OVERVOLTAGE Vd: " + String(ext_voltage_vd, 1) + "V / Порог: " + String(lim_vd, 0) + "V";
    }
    else if (swr > lim_swr) {
        reason = "HIGH SWR: " + String(swr, 2) + " / Порог: " + String(lim_swr, 1);
    }
    else if (wattsPin > lim_pin) { 
        reason = "OVERDRIVE Pin: " + String(wattsPin, 1) + "W / Порог: " + String(lim_pin, 0) + "W";
    }
    else if (wattsFwd > lim_pout) {
        reason = "OVERPOWER FWD: " + String(wattsFwd, 0) + "W / Порог: " + String(lim_pout, 0) + "W";
    }
    else if (wattsRef > lim_pref) {
        reason = "HIGH REFLECTED: " + String(wattsRef, 1) + "W / Порог: " + String(lim_pref, 0) + "W";
    }
    else if (current_band_name == "---" && wattsFwd > 5.0f && 25.0f > lim_lpf) {
        reason = "LPF FAULT: Неверный диапазон ФНЧ!";
    }
    static unsigned long txStartMillis = 0;
    if (wattsFwd > 5.0f) { 
        if (txStartMillis == 0) txStartMillis = millis();
        if (lim_tx_time > 0 && (millis() - txStartMillis >= (unsigned long)lim_tx_time * 1000)) {
            reason = "TX TIMEOUT: Превышено время несущей " + String(lim_tx_time) + " сек";
        }
    } else { txStartMillis = 0; }
    
    if (ext_temperature > lim_temp) {
        reason = "OVERHEAT Temp: " + String(ext_temperature, 1) + "C / Порог: " + String(lim_temp, 0) + "C";
    }

    if (reason != "") {
        is_tripped = true; trip_reason = reason;
        digitalWrite(18, LOW); 
        writeRegister595(0x00); 
        Serial0.println("\n!!! EMERGENCY PROTECTION TRIP !!! Причина: " + trip_reason);
    }
}

void applyAntennaHardware(int antId) {
    if (antId < 1 || antId > 4) antId = 1;
    active_antenna_id = antId;

    current_32bit_lpf_mask &= ~(BIT_ANTENNA_1 | BIT_ANTENNA_2 | BIT_ANTENNA_3 | BIT_ANTENNA_4);
    if (antId == 1) current_32bit_lpf_mask |= BIT_ANTENNA_1;
    else if (antId == 2) current_32bit_lpf_mask |= BIT_ANTENNA_2;
    else if (antId == 3) current_32bit_lpf_mask |= BIT_ANTENNA_3;
    else if (antId == 4) current_32bit_lpf_mask |= BIT_ANTENNA_4;

    writeRegister595(current_32bit_lpf_mask);
}

void autoSelectAntennaForBand(int bandIdx) {
    if (bandIdx < 0 || bandIdx >= BAND_COUNT) return;
    int targetAnt = band_antenna_map[bandIdx];
    if (targetAnt < 1 || targetAnt > 4) targetAnt = 1;
    if (active_antenna_id != targetAnt) {
        applyAntennaHardware(targetAnt);
    }
}

void autoSelectBand(double freqHz) {
    uint8_t mask = 0x00;
    int newBandIdx = -1;
    
    // СТРОГО ПО НОВОЙ АППАРАТНОЙ СХЕМЕ ПОДКЛЮЧЕНИЯ ПЕРВОГО ЧИПА 74HC595
    if (freqHz >= 1500000.0 && freqHz <= 2500000.0) {
        mask = 0x01; // 160м ➔ Бит 0 (Физическая ножка 15 / Q0) - РАБОТАЕТ
        current_band_name = "160m";
        newBandIdx = BAND_160M;
    } 
    else if (freqHz > 2500000.0 && freqHz <= 4500000.0) {
        mask = 0x02; // 80м ➔ Бит 1 (Физическая ножка 1 / Q1)
        current_band_name = "80m";
        newBandIdx = BAND_80M;
    } 
    else if (freqHz > 4500000.0 && freqHz <= 9000000.0) {
        mask = 0x04; // 40м ➔ Бит 2 (Физическая ножка 2 / Q2)
        current_band_name = "40m";
        newBandIdx = BAND_40M;
    } 
    else if (freqHz > 9000000.0 && freqHz <= 15000000.0) {
        mask = 0x08; // 30м/20м ➔ Бит 3 (Физическая ножка 3 / Q3)
        current_band_name = "20m/30m";
        newBandIdx = BAND_20M;
    } 
    else if (freqHz > 15000000.0 && freqHz <= 22000000.0) {
        mask = 0x10; // 17м/12м ➔ Бит 4 (Физическая ножка 4 / Q4)
        current_band_name = "17m/12m";
        newBandIdx = BAND_17M;
    } 
    else if (freqHz > 22000000.0 && freqHz <= 35000000.0) {
        mask = 0x20; // 12м/10м ➔ Бит 5 (Физическая ножка 5 / Q5)
        current_band_name = "12m/10m";
        newBandIdx = BAND_10M;
    } 
    else if (freqHz > 35000000.0 && freqHz <= 60000000.0) {
        mask = 0x40; // 6м ➔ Бит 6 (Физическая ножка 6 / Q6)
        current_band_name = "6m";
        newBandIdx = BAND_6M;
    } 
    else {
        mask = 0x00;
        current_band_name = "---";
        newBandIdx = -1;
    }

    bool bandChanged = (newBandIdx != current_band_index);
    current_band_index = newBandIdx;

    // Ювелирно интегрируем маску ФНЧ в первый байт 32-битной цепочки, сохраняя биты реле секвенсора
    uint32_t oldMask = current_32bit_lpf_mask;
    current_32bit_lpf_mask = (current_32bit_lpf_mask & 0xFFFFFF00) | mask;
    
    if (current_32bit_lpf_mask != oldMask) { 
        writeRegister595(current_32bit_lpf_mask); 
    }

    if (bandChanged && newBandIdx >= 0) {
        autoSelectAntennaForBand(newBandIdx);
    }
}


void calculateRfParameters(float rawVoltFwd, float rawVoltRef) {
    if (rawVoltFwd > 0.26f) { 
        float dbmFwdInput = ((rawVoltFwd - 0.25f) / CAL_AD8307_SLOPE) + cal_intercepts;
        float dbmFwdTotal = dbmFwdInput + COUPLER_ATTN;
        wattsFwd = pow(10.0f, dbmFwdTotal / 10.0f) / 1000.0f;
    } else { wattsFwd = 0.0f; }
    if (rawVoltRef > 0.26f && wattsFwd > 0.5f) { 
        float dbmRefInput = ((rawVoltRef - 0.25f) / CAL_AD8307_SLOPE) + cal_intercepts;
        float dbmRefTotal = dbmRefInput + COUPLER_ATTN;
        wattsRef = pow(10.0f, dbmRefTotal / 10.0f) / 1000.0f;
    } else { wattsRef = 0.0f; }
    if (wattsFwd > 0.5f) { 
        float gamma = sqrt(wattsRef / wattsFwd);
        if (gamma < 0.98f) { swr = (1.0f + gamma) / (1.0f - gamma); } else { swr = 9.99f; }
        if (swr < 1.00f) swr = 1.00f;
    } else { swr = 1.00f; }
}

// ВОССТАНОВЛЕНО СТРОГО ПО ТЗ: Двухточечный расчет калибровки AD8307
  void processTwoPointCalibration() {
    // СТРОГО ИСПРАВЛЕНО ПО ТЗ: Опорные реперы переведены на 5 Вт (37 dBm) и 500 Вт (57 dBm)
    float dbmPt1 = 37.0f - COUPLER_ATTN; 
    float dbmPt2 = 57.0f - COUPLER_ATTN; 
    if (lastVoltPt2 > lastVoltPt1 && lastVoltPt1 > 0.2f) {
        CAL_AD8307_SLOPE = (lastVoltPt2 - lastVoltPt1) / (dbmPt2 - dbmPt1);
        cal_intercepts = dbmPt1 - ((lastVoltPt1 - 0.25f) / CAL_AD8307_SLOPE);
        prefs.begin("calib", false);
        prefs.putFloat("slope", CAL_AD8307_SLOPE);
        prefs.putFloat("intercept", cal_intercepts);
        prefs.end();
    }
}

// --- TCI: парсинг и обработка команд протокола Expert Electronics ---
void tciApplyFrequency(uint64_t freqHz) {
    if (freqHz < 100000ULL || freqHz > 600000000ULL) return;
    final_frequency = (uint32_t)freqHz;
    last_calculated_frequency = (double)freqHz;
    autoSelectBand(last_calculated_frequency);
}

void tciHandleCommand(const char* cmd) {
    if (cmd == NULL || cmd[0] == '\0') return;

    if (strncasecmp(cmd, "vfo:", 4) == 0) {
        const char* lastComma = strrchr(cmd, ',');
        if (lastComma != NULL) {
            uint64_t freqHz = strtoull(lastComma + 1, NULL, 10);
            tciApplyFrequency(freqHz);
        }
    } else if (strncasecmp(cmd, "if:", 3) == 0) {
        const char* lastComma = strrchr(cmd, ',');
        if (lastComma != NULL) {
            uint64_t freqHz = strtoull(lastComma + 1, NULL, 10);
            tciApplyFrequency(freqHz);
        }
    } else if (strncasecmp(cmd, "tx_frequency:", 13) == 0) {
        uint64_t freqHz = strtoull(cmd + 13, NULL, 10);
        tciApplyFrequency(freqHz);
    }
}

void tciParseBuffer(const char* data, size_t length) {
    if (data == NULL || length == 0) return;
    char line[160];
    size_t linePos = 0;

    for (size_t i = 0; i < length; i++) {
        char c = data[i];
        if (c == ';') {
            if (linePos > 0) {
                line[linePos] = '\0';
                tciHandleCommand(line);
                linePos = 0;
            }
        } else if (c >= 32 && c <= 126 && linePos < sizeof(line) - 1) {
            line[linePos++] = c;
        }
    }
}

void tciOnEvent(WStype_t type, uint8_t* payload, size_t length) {
    switch (type) {
        case WStype_DISCONNECTED:
            tci_connected = false;
            Serial0.println("[TCI] Disconnected");
            break;
        case WStype_CONNECTED:
            tci_connected = true;
            Serial0.printf("[TCI] Connected to %s:%u\n", tci_host.c_str(), tci_port);
            tciSocket.sendTXT("vfo:0;");
            break;
        case WStype_TEXT:
            if (payload != NULL && length > 0) {
                tciParseBuffer((const char*)payload, length);
            }
            break;
        default:
            break;
    }
}

void tciDisconnect() {
    if (tci_socket_started) {
        tciSocket.disconnect();
        tci_socket_started = false;
    }
    tci_connected = false;
}

void tciService() {
    if (ext_protocol_type != 1) {
        if (tci_socket_started || tci_connected) tciDisconnect();
        return;
    }

    if (!tci_socket_started) {
        if (millis() - tci_last_reconnect >= TCI_RECONNECT_MS) {
            tci_last_reconnect = millis();
            tciSocket.begin(tci_host.c_str(), tci_port, "/");
            tciSocket.onEvent(tciOnEvent);
            tciSocket.setReconnectInterval(TCI_RECONNECT_MS);
            tci_socket_started = true;
