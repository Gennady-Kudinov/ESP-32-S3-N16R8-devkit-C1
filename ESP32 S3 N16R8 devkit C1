// Высокоскоростной бинарный шлюз шкал мощности (раз в 60 мс)
document.addEventListener('DOMContentLoaded', () => {
  const bFwd = document.getElementById('bFwd');
  const bRef = document.getElementById('bRef');
  const bSwr = document.getElementById('bSwr');
  let visualFwdWatts = 0.0; let visualRefWatts = 0.0;
  setInterval(() => {
    fetch('/fast_data').then(res => res.arrayBuffer()).then(buf => {
      const view = new Float32Array(buf);
      if (view.length >= 3) {
        let fwdWatts = view[0]; let refWatts = view[1]; let swrVal = view[2];
        document.getElementById('txtFwd').innerText = fwdWatts.toFixed(0);
        document.getElementById('txtRef').innerText = refWatts.toFixed(1);
        document.getElementById('txtSwr').innerText = swrVal.toFixed(2);
        
        if (fwdWatts > visualFwdWatts) { visualFwdWatts = fwdWatts; }
        else { visualFwdWatts = visualFwdWatts * 0.85 + fwdWatts * 0.15; }
        if (refWatts > visualRefWatts) { visualRefWatts = refWatts; }
        else { visualRefWatts = visualRefWatts * 0.85 + refWatts * 0.15; }
        
        let segFwd = 0;
        if (visualFwdWatts >= 1.0) {
          let currentDbm = 10 * Math.log10(visualFwdWatts * 1000);
          if (currentDbm >= 30.0) { segFwd = Math.round(((currentDbm - 30.0) / (64.77 - 30.0)) * 40); }
          if (segFwd > 40) segFwd = 40; if (segFwd < 0) segFwd = 0;
        }
        let segRef = 0;
        if (visualRefWatts >= 0.1) {
          let refDbm = 10 * Math.log10(visualRefWatts * 1000);
          if (refDbm >= 20.0) { segRef = Math.round(((refDbm - 20.0) / (50.0 - 20.0)) * 40); }
          if (segRef > 40) segRef = 40; if (segRef < 0) segRef = 0;
        }
        let segSwr = 0;
        if (swrVal > 1.0) {
          if (swrVal <= 1.5) segSwr = Math.round(((swrVal - 1.0) / 0.5) * 5);
          else if (swrVal <= 2.0) segSwr = 5 + Math.round(((swrVal - 1.5) / 0.5) * 5);
          else if (swrVal <= 3.0) segSwr = 10 + Math.round(((swrVal - 2.0) / 1.0) * 10);
          else if (swrVal <= 5.0) segSwr = 20 + Math.round(((swrVal - 3.0) / 2.0) * 10);
          else segSwr = 30 + Math.round(((swrVal - 5.0) / 4.99) * 10);
          if (segSwr > 40) segSwr = 40;
        }
        
        const fCells = bFwd.getElementsByClassName('bar-segment');
        const rCells = bRef.getElementsByClassName('bar-segment');
        const sCells = bSwr.getElementsByClassName('bar-segment');
        for (let i = 0; i < 40; i++) {
          if (i < segFwd) fCells[i].style.background = i > 33 ? '#ff3333' : '#ffaa00'; else fCells[i].style.background = '#14161d';
          if (i < segRef) rCells[i].style.background = i > 30 ? '#ff3333' : '#ffaa00'; else rCells[i].style.background = '#14161d';
          if (i < segSwr) sCells[i].style.background = swrVal > 2.0 ? '#ff3333' : (swrVal > 1.5 ? '#ffaa00' : '#00ff66'); else sCells[i].style.background = '#14161d';
        }
        
        const ledAmp = document.getElementById('led-amp');
        const ledTuner = document.getElementById('led-tuner');
        if (fwdWatts > 5.0) { ledAmp.className = 'btn-led led-active-green'; ledTuner.className = 'btn-led led-active-green'; }
        else { ledAmp.className = 'btn-led'; ledTuner.className = 'btn-led led-active-orange'; }
        // Прописываем инициализацию индикатора кнопки BYPASS в шлюзе шкал
        const ledBypass = document.getElementById('led-bypass');
        if (!ledBypass.className) ledBypass.className = 'btn-led led-active-orange';
      }           
    }).catch(err => console.error(err));
  }, 60);
});
</script>
