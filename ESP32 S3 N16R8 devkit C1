// Сетевой обработчик кнопки ручного сброса триггера аварии after устранения проблемы в шеке
void handleResetTrip() {
  is_tripped = false;
  trip_reason = "SYSTEM OK";
  digitalWrite(18, HIGH); // ВОССТАНОВЛЕНИЕ РАБОТЫ: Подаем HIGH на аппаратный пин защиты GPIO 18
  
  // --- АППАРАТНО ВЫКЛЮЧАЕМ ЗУМЕР НА ПОРТУ А7 ПРИ СБРОСЕ АВАРИИ ---
  selectI2CChannel(1);
  Wire.beginTransmission(MCP_ADDR);
  Wire.write(GPIOA_REG);
  Wire.write(0x00); // Сбрасываем пин А7 в ноль (0V) -> зумер молчит
  Wire.endTransmission();
  selectI2CChannel(0); // Возвращаем мультиплексор на скоростной ADS1115
  
  double tempFreq = last_calculated_frequency;
  if(tempFreq > 0.0) { autoSelectBand(tempFreq); }
  server.send(200, "text/plain", "Защита сброшена! Усилитель вернулся в рабочий режим.");
}

